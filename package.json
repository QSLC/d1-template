{
	"name": "d1-template",
	"description": "Production-grade Cloudflare Worker + D1 with Stripe, Agent, Metrics & API Tiers",
	"cloudflare": {
		"label": "Worker + D1 Database + Stripe",
		"products": [
			"Workers",
			"D1"
		],
		"categories": [
			"storage",
			"payments"
		],
		"docs_url": "https://developers.cloudflare.com/d1/",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/6c63cca8-354a-4951-45a0-d58769ac6f00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/aa6158f1-7711-4485-f134-a8c802c0a800/preview",
		"publish": true
	},
	"dependencies": {
		"stripe": "^15.8.0"
	},
	"devDependencies": {
		"typescript": "5.9.3",
		"wrangler": "4.88.0",
		"@cloudflare/workers-types": "^4.20250107.1"
	},
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types",
		"check": "tsc && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "pnpm seedLocalD1 && wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"seedLocalD1": "wrangler d1 migrations apply DB --local",
		"seed": "wrangler d1 execute DB --file ./migrations/seed.sql --remote"
	}
}
