{
	"compatibility_date": "2026-06-14",
	"main": "src/index.ts",
	"name": "d1-template",
	"upload_source_maps": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_id": "539b16b9-d991-4326-9fc5-5b87c1855354",
			"database_name": "d1-template-database"
		}
	],
	"observability": {
		"enabled": true
	},
	"env": {
		"production": {
			"name": "d1-template-prod"
		},
		"staging": {
			"name": "d1-template-staging"
		}
	},
	"vars": {
		"FRONTEND_URL": "https://localhost:3000"
	},
	"env_overrides": {
		"production": {
			"vars": {
				"FRONTEND_URL": "https://yourdomain.com"
			}
		}
	}
}
